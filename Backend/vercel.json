{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/contact",
      "dest": "/api/contact.js"
    },
    {
      "src": "/chat",
      "dest": "/api/chat.js"
    },
    {
      "src": "/test",
      "dest": "/api/test.js"
    }
  ]
}
